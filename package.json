{
  "name": "weekly-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "predeploy": "npm run build",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
